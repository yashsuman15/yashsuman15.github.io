# Formspree form ID — get yours at https://formspree.io
# 1. Sign up for a free account at https://formspree.io
# 2. Create a new form
# 3. Copy the form ID (the part after /f/ in the endpoint URL)
# 4. Create a file called .env.local in this directory and paste:
#    VITE_FORMSPREE_ID=your_form_id_here
VITE_FORMSPREE_ID=your_form_id_here

# Alt Cunningham Chat — Cloudflare Worker proxy URL
# 1. Deploy the Cloudflare Worker from serverless/worker.js
# 2. Set your GEMINI_API_KEY as a secret in the worker
# 3. Paste the worker URL below (e.g., https://alt-chat.your-account.workers.dev)
VITE_CHAT_API_URL=your_cloudflare_worker_url_here
